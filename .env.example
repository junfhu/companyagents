APP_NAME=AI Delivery Operating System
APP_ENV=development
APP_DEBUG=true
APP_AUTO_CREATE_TABLES=true
APP_RUNTIME_WORKERS_ENABLED=true
APP_RUNTIME_POLL_INTERVAL_SECONDS=2.0
APP_RUNTIME_WORKER_ACTOR_ID=runtime-orchestrator
APP_OPENCLAW_ENABLED=false
APP_OPENCLAW_COMMAND=openclaw
APP_OPENCLAW_COMMAND_TIMEOUT_SECONDS=300
APP_OPENCLAW_AGENTS_ROOT=/root/.openclaw/agents
APP_OPENCLAW_DEFAULT_DISPATCH_AGENT=shangshu
APP_OPENCLAW_AGENT_MAP_JSON={"Engineering":"gongbu","Data":"hubu","Content":"libu","Operations":"bingbu","Security":"xingbu"}

HOST=0.0.0.0
PORT=8100

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=delivery_os
POSTGRES_USER=delivery_os
POSTGRES_PASSWORD=change-me

# Example for local sqlite dev:
# DATABASE_URL_OVERRIDE=sqlite+aiosqlite:///./delivery_os.db

REDIS_URL=redis://localhost:6379/1
